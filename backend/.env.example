# Supabase: Project Settings -> Database -> Connection string (use the pooler URI for Railway)
DATABASE_URL=postgresql://postgres.<ref>:<db-password>@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
# Supabase: Project Settings -> API -> JWT Settings -> JWT Secret (the shared HS256 secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Comma-separated allowed origins for the browser frontend (set to your Vercel URL later)
CORS_ORIGINS=*
# Needed for asymmetric (ES256) token verification via JWKS
SUPABASE_URL=https://scnylilkzuiswypdpqkp.supabase.co
# Anthropic API for the AI core
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
